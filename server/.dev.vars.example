# Copy to `.dev.vars` for local `wrangler dev`. For deployed
# production secrets, use `wrangler secret put <NAME>` instead — the
# CLI uploads them to Cloudflare's secret store, never to git.

# Resend transactional-email API key. Get one at https://resend.com.
# In dev, set to "stub" to skip the actual fetch and log the email
# body to the console instead.
RESEND_API_KEY="stub"

# Paddle webhook signing secret. Found in your Paddle dashboard
# under Developer Tools → Notifications → (your endpoint) → Secret.
PADDLE_WEBHOOK_SECRET="stub"

# Paddle API key (server-side, used to look up customers/subscriptions
# during the webhook reconcile step).
PADDLE_API_KEY="stub"
