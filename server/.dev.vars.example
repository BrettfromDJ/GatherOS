# Copy to `.dev.vars` for local `wrangler dev`. For deployed
# production secrets, use `wrangler secret put <NAME>` instead — the
# CLI uploads them to Cloudflare's secret store, never to git.

# Resend transactional-email API key. Get one at https://resend.com.
# In dev, set to "stub" to skip the actual fetch and log the email
# body to the console instead.
RESEND_API_KEY=stub

# Lemon Squeezy webhook signing secret. You set this when you create
# the webhook destination in the LS dashboard (Settings → Webhooks).
# Use "stub" locally to bypass signature verification during dev.
LEMONSQUEEZY_WEBHOOK_SECRET=stub

# Lemon Squeezy API key (server-side, used to create checkouts and
# fetch the customer-portal URL). Settings → API → New API Key.
# Test-mode keys work for both test and live API calls — the test_mode
# flag on the request controls whether real money flows.
LEMONSQUEEZY_API_KEY=stub
