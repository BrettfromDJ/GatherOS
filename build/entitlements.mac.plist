<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!--
      Entitlements for the hardened-runtime + notarized macOS build.
      Pinned here (rather than relying on electron-builder's bundled
      default) so an electron-builder upgrade can't silently remove
      one and break notarized launches.
    -->

    <!-- V8 needs writable + executable memory for JIT compilation. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!--
      Native modules — better-sqlite3, sharp, @img/* — ship as .node
      binaries that aren't signed by Apple's notary. With hardened
      runtime enabled, library validation would refuse to load them
      and the renderer would crash at require-time. This disables
      that check for our process only.
    -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
  </dict>
</plist>
